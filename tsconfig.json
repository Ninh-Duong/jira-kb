{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/*"],
      "@web/*": ["web/src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*", "web/src/**/*", "vite.config.ts"],
  "exclude": ["dist", "node_modules", "workspaces", "data", "kb", "indexes"]
}
